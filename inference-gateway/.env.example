# Server
GATEWAY_PORT=3001
ADMIN_PORT=3002
NODE_ENV=production
GATEWAY_URL=https://inference.getplexo.com
ADMIN_URL=https://gateway-admin.getplexo.com

# Admin auth (Auth.js)
# AUTH_URL is injected automatically from ADMIN_URL in docker-compose.yml — do not set separately.
AUTH_SECRET=change-me-generate-with-openssl-rand-hex-32

# Database (shared by gateway and admin)
DATABASE_URL=postgresql://gateway:gateway@postgres:5432/plexo_gateway
POSTGRES_PASSWORD=gateway

# Cache (gateway only)
VALKEY_URL=redis://valkey:6379

# Upstream provider keys (Plexo's own — never exposed to instances)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
DEEPSEEK_API_KEY=

# Anomaly alerting
ANOMALY_WEBHOOK_URL=
ANOMALY_WEBHOOK_SECRET=

# Signing
SIGNING_PEPPER=b5cb6076840748b61e2b535d56417fae715db15f5322c3664d4a34bba4ec77c9

# Analytics (PostHog)
POSTHOG_API_KEY=phc_NNJrGRLnopoR73cofmbbHEG05S2kSfCz93nQVOJlxQH
POSTHOG_HOST=https://telemetry.getplexo.com
NEXT_PUBLIC_POSTHOG_KEY=phc_NNJrGRLnopoR73cofmbbHEG05S2kSfCz93nQVOJlxQH
NEXT_PUBLIC_POSTHOG_HOST=https://telemetry.getplexo.com
